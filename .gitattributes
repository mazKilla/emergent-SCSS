# Auto-detect text files and normalise line endings to LF on commit
* text=auto eol=lf

# Explicitly declare text files
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.txt       text eol=lf
*.py        text eol=lf
*.sh        text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
*.toml      text eol=lf
*.lock      text eol=lf
*.gitconfig text eol=lf
*.npmrc     text eol=lf

# Shell scripts must always use LF (POSIX requirement)
*.sh        text eol=lf
*.bash      text eol=lf

# Windows batch scripts use CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files — prevent diff/merge corruption
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.7z        binary
*.mp4       binary
*.mp3       binary
*.webm      binary

# Linguist overrides
memory/test_credentials.md linguist-generated

# Diff drivers for readability
*.json      diff=json
*.md        diff=markdown
*.py        diff=python
*.ts        diff=typescript
*.tsx       diff=typescript
