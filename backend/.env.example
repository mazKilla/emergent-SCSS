# SCSS AB ADVOCATE — Backend Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env — it is gitignored

# MongoDB connection (Emergent-managed, do not change key name)
MONGO_URL=mongodb://localhost:27017
DB_NAME=scss_advocate

# Emergent Universal LLM Key (covers Claude Sonnet 4.5)
# Get your key from: Emergent Profile -> Universal Key -> Add Balance
EMERGENT_LLM_KEY=sk-emergent-xxxxxxxxxxxxxxxxxxxx

# xAI API Key (for Grok 3)
# Obtain from: https://console.x.ai
XAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL (optional — for importing emails from Email-Transformer app)
# Only required if connecting to a local/remote PostgreSQL instance
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=postgres
PG_USER=postgres
PG_PASSWORD=your_password_here
