# SCSS AB ADVOCATE — Frontend Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env — it is gitignored

# Backend API base URL (Emergent-managed preview URL or your production domain)
# Example for local dev: http://localhost:8001
# Example for Emergent preview: https://<your-app-id>.preview.emergentagent.com
REACT_APP_BACKEND_URL=https://your-app-id.preview.emergentagent.com
